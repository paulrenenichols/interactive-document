{
  "name": "interactive-document",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "nx run-many -t build --projects=api,frontend --parallel=1",
    "build:frontend": "nx build frontend",
    "build:api": "nx build api",
    "serve:frontend": "nx serve frontend",
    "serve:api": "nx serve api",
    "migrate": "node scripts/run-migrations.mjs",
    "start": "docker compose up -d",
    "stop": "docker compose down",
    "dev": "docker compose -f docker-compose.dev.yml up --build",
    "storybook": "nx storybook frontend",
    "lint": "nx run-many -t lint --projects=api,frontend",
    "test": "nx run-many -t test --projects=api,frontend"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@tanstack/react-query": "^5.90.21",
    "bcrypt": "^6.0.0",
    "fastify": "^5.1.0",
    "jsonwebtoken": "^9.0.3",
    "next": "16.1.6",
    "papaparse": "^5.5.3",
    "pg": "^8.13.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^2.15.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.3",
    "@eslint/js": "^10.0.1",
    "@nx/eslint": "22.5.3",
    "@nx/js": "22.5.4",
    "@nx/storybook": "22.5.3",
    "@nx/web": "22.5.4",
    "@storybook/nextjs": "10.2.17",
    "@storybook/react": "10.2.17",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@tailwindcss/postcss": "4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.0.0",
    "@types/papaparse": "^5.5.2",
    "@types/pg": "^8.16.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "eslint": "^10.0.3",
    "eslint-plugin-react": "^7.37.5",
    "jsdom": "^28.1.0",
    "nx": "22.5.3",
    "prettier": "~3.6.2",
    "storybook": "10.2.17",
    "tailwindcss": "4",
    "ts-node": "10.9.1",
    "tslib": "^2.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.1.0"
  }
