# PostgreSQL connection string (required for DB features)
DATABASE_URL=postgres://user:password@localhost:5432/interactive_document
# JWT signing secret (required for auth)
JWT_SECRET=your-secret-at-least-32-chars
# Server port
PORT=3000
# CORS allowed origins (production: set to comma-separated frontend URLs, e.g. https://app.yourdomain.com; leave unset for local dev)
# CORS_ORIGINS=https://app.yourdomain.com
