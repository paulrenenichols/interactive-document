{
  "name": "frontend",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/frontend",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "next build",
        "cwd": "apps/frontend"
      },
      "configurations": {
        "production": {}
      },
      "outputs": ["{projectRoot}/.next"]
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "next dev",
        "cwd": "apps/frontend"
      },
      "configurations": {
        "production": {
          "command": "next start",
          "cwd": "apps/frontend"
        }
      }
    },
    "storybook": {
      "executor": "nx:run-commands",
      "options": {
        "command": "storybook dev -p 6006 --config-dir apps/frontend/.storybook"
      }
    },
    "build-storybook": {
      "executor": "nx:run-commands",
      "outputs": ["dist/storybook/frontend"],
      "options": {
        "command": "storybook build --config-dir apps/frontend/.storybook -o dist/storybook/frontend"
      }
    }
  },
  "tags": []
}
